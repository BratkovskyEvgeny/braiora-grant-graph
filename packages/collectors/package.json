{
  "name": "@ogg/collectors",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "collect:demo": "tsx src/demo-seed.ts",
    "collect:optimism": "tsx src/optimism/cli.ts",
    "export:release": "tsx src/export-release.ts"
  },
  "dependencies": {
    "@ogg/schema": "workspace:*",
    "@ogg/sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3"
  }
}
